{
  "manifest_version": 3,
  "name": "MarkUI",
  "version": "1.0",
  "description": "EN - This open source extension help you customize your homepage from ugly default page to customizable page with custom icons, fonts, styles, colors etc",
  "action": {
    "default_popup": "popup.html"
  },
     "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
"permissions": [
    "storage",
    "bookmarks",
    "tabs"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "stellar-tab@extension",
      "strict_min_version": "57.0"
    }
  },
  "icons": {
    "48": "icon48.png",
    "96": "icon96.png"
  }
}