{
  "manifest_version": 3,
  "name": "MonoUI",
  "version": "1.0.2",
  "description": "Customizable homepage with icons, fonts, and styles.",

  "browser_specific_settings": {
    "gecko": {
      "id": "stellar-tab@extension",
      "strict_min_version": "109.0" 
    }
  },

  "chrome_url_overrides": {
    "newtab": "popup.html"
  },

  "chrome_settings_overrides": {
  "homepage": "popup.html"
},

 "action": {
    "default_popup": "panel.html",
    "default_icon": {
      "48": "Icons/Icon48.png"
    }
  },


  "permissions": [
    "storage",
    "bookmarks",
    "tabs"
  ],

  "icons": {
    "16": "Icons/Icon16.png",
    "32": "Icons/Icon32.png",
    "48": "Icons/Icon48.png",
    "128": "Icons/Icon128.png"
  }
}
